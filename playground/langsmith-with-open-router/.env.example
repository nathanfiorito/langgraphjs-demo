# OpenRouter — obtenha sua chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_MODEL=openai/gpt-4o-mini

# LangSmith — observabilidade e tracing
# Obtenha sua chave em https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=sua_chave_langsmith_aqui
LANGCHAIN_PROJECT=langsmith-openrouter-demo
